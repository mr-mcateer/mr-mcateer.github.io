# Canvas Agent Grader -- Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit the real .env file.

# Canvas LMS
CANVAS_API_URL=https://your-canvas-instance.instructure.com
CANVAS_API_TOKEN=

# Google Gemini (for AI grading)
GEMINI_API_KEY=

# DLP (optional overrides)
# Set to "true" to block API calls entirely if PII is detected
# Default "false" redacts and continues
DLP_STRICT_MODE=false
